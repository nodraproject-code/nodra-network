# NODRA Token Deployment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains private keys!

# Private key of the wallet deploying the contract (WITHOUT 0x prefix)
PRIVATE_KEY=

# BNB Smart Chain Testnet RPC endpoint
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-e05a9c41c88f10b3393149fb8c4430341f12d9359:

# BNB Smart Chain Mainnet RPC endpoint
# WARNING: Do NOT deploy to mainnet without explicit approval!
BSC_MAINNET_RPC_URL=https://bsc-dataseed1.binance.org:443

# BSCScan API Key for contract verification
BSCSCAN_API_KEY=

# Network selection (hardhat, bscTestnet, bscMainnet)
NETWORK=bscTestnet
